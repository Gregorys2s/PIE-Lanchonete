<?xml version="1.0" encoding="UTF-8" standalone="yes"?>
<persistence xmlns="https://jakarta.ee/xml/ns/persistence"
             xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
             xsi:schemaLocation="https://jakarta.ee/xml/ns/persistence
                                 https://jakarta.ee/xml/ns/persistence/persistence_3_0.xsd"
             version="3.0">


    <persistence-unit name="LanchonetePU">
        <provider>org.hibernate.jpa.HibernatePersistenceProvider</provider>


        <class>com.github.Gregorys2s.entity.CardapioEntity</class>
        <class>com.github.Gregorys2s.entity.IngredienteEntity</class>
        <class>com.github.Gregorys2s.entity.PedidosEntity</class>
        <class>com.github.Gregorys2s.entity.ItemPedidosEntity</class>


        <properties>
            <property name="jakarta.persistence.jdbc.driver" value="org.postgresql.Driver" />

            <property name="jakarta.persistence.jdbc.url" value="jdbc:postgresql://localhost:5432/Lanchonete" />

            <property name="jakarta.persistence.jdbc.user" value="postgres" />
            <property name="jakarta.persistence.jdbc.password" value="admin" />

            <property name="hibernate.hbm2ddl.auto" value="update" />

            <property name="hibernate.show_sql" value="true" />
            <property name="hibernate.format_sql" value="true" />
            <property name="hibernate.highlight_sql" value="true" />
        </properties>
    </persistence-unit>
</persistence>